/*
╔══════════════════════════════════════════════════════════════════════════════╗
║  nextflow.config — Resource & Execution Profiles                            ║
╚══════════════════════════════════════════════════════════════════════════════╝
*/

// ─── GLOBAL DEFAULTS ───────────────────────────────────────────────────────
manifest {
    name        = "Germline Variant Calling Pipeline"
    author      = "Etienne Kabongo"
    description = "GATK4 Best Practices: FastQC → Trim → BWA → BQSR → HC → SnpEff"
    version     = "1.0.0"
    nextflowVersion = ">=23.04.0"
}

// ─── PROCESS LABELS (resource tiers) ──────────────────────────────────────
process {
    // Default
    cpus   = 1
    memory = "4.GB"
    time   = "2.h"
    shell  = ["/bin/bash", "-euo", "pipefail"]

    withLabel: process_low {
        cpus   = 2
        memory = "8.GB"
        time   = "4.h"
    }
    withLabel: process_medium {
        cpus   = 4
        memory = "16.GB"
        time   = "8.h"
    }
    withLabel: process_high {
        cpus   = 8
        memory = "32.GB"
        time   = "24.h"
    }

    // Tool-specific overrides
    withName: HAPLOTYPE_CALLER {
        cpus   = 4
        memory = "16.GB"
        time   = "12.h"
    }
    withName: GENOTYPE_GVCFS {
        cpus   = 4
        memory = "16.GB"
        time   = "8.h"
    }
    withName: BWA_MEM {
        cpus   = 8
        memory = "16.GB"
        time   = "12.h"
    }
}

// ─── EXECUTION PROFILES ────────────────────────────────────────────────────
profiles {

    // ── Local execution (default) ──────────────────────────────────────
    local {
        process.executor = "local"
        executor {
            name    = "local"
            cpus    = 8
            memory  = "32 GB"
        }
        docker.enabled  = false
        singularity.enabled = false
    }

    // ── Docker (recommended for reproducibility) ───────────────────────
    docker {
        docker.enabled     = true
        docker.runOptions  = "-u \$(id -u):\$(id -g)"
        docker.userEmulation = true

        process {
            withName: "FASTQC_RAW|FASTQC_TRIMMED" {
                container = "staphb/fastqc:0.12.1"
            }
            withName: FASTP {
                container = "staphb/fastp:0.23.4"
            }
            withName: "BWA_INDEX|BWA_MEM" {
                container = "staphb/bwa-mem2:2.2.1"
            }
            withName: "SAMTOOLS_SORT|SAMTOOLS_INDEX|FLAGSTAT|COVERAGE_STATS" {
                container = "staphb/samtools:1.19"
            }
            withName: "MARK_DUPLICATES|BASE_RECALIBRATOR|APPLY_BQSR|HAPLOTYPE_CALLER|COMBINE_GVCFS|GENOTYPE_GVCFS|SELECT_SNP|SELECT_INDEL|FILTER_SNP|FILTER_INDEL|MERGE_VCFS" {
                container = "broadinstitute/gatk:4.4.0.0"
            }
            withName: SNPEFF {
                container = "staphb/snpeff:5.2"
            }
            withName: "SUMMARIZE" {
                container = "python:3.11-slim"
            }
            withName: MULTIQC {
                container = "staphb/multiqc:1.19"
            }
        }
    }

    // ── Singularity (for HPC without Docker) ──────────────────────────
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true

        process {
            withName: "FASTQC_RAW|FASTQC_TRIMMED" {
                container = "docker://staphb/fastqc:0.12.1"
            }
            withName: FASTP {
                container = "docker://staphb/fastp:0.23.4"
            }
            withName: "BWA_INDEX|BWA_MEM" {
                container = "docker://staphb/bwa-mem2:2.2.1"
            }
            withName: "SAMTOOLS_SORT|SAMTOOLS_INDEX|FLAGSTAT|COVERAGE_STATS" {
                container = "docker://staphb/samtools:1.19"
            }
            withName: "MARK_DUPLICATES|BASE_RECALIBRATOR|APPLY_BQSR|HAPLOTYPE_CALLER|COMBINE_GVCFS|GENOTYPE_GVCFS|SELECT_SNP|SELECT_INDEL|FILTER_SNP|FILTER_INDEL|MERGE_VCFS" {
                container = "docker://broadinstitute/gatk:4.4.0.0"
            }
            withName: SNPEFF {
                container = "docker://staphb/snpeff:5.2"
            }
            withName: MULTIQC {
                container = "docker://staphb/multiqc:1.19"
            }
        }
    }

    // ── SLURM cluster ─────────────────────────────────────────────────
    slurm {
        process.executor = "slurm"
        process.queue    = "normal"

        executor {
            name           = "slurm"
            queueSize      = 500
            submitRateLimit = "10/1sec"
        }

        // SLURM-specific resource directives
        process {
            withLabel: process_low    { clusterOptions = "--account=def-jacquemont" }
            withLabel: process_medium { clusterOptions = "--account=def-jacquemont" }
            withLabel: process_high   { clusterOptions = "--account=def-jacquemont" }
        }
    }

    // ── AWS Batch ─────────────────────────────────────────────────────
    aws {
        aws.region     = "us-east-1"
        process.executor = "awsbatch"
        process.queue    = "nextflow-batch-queue"
        aws.batch.cliPath = "/home/ec2-user/miniconda/bin/aws"
        workDir = "s3://your-bucket/nextflow-work"
    }

    // ── Test profile (small dataset, fast) ────────────────────────────
    test {
        params.samplesheet = "data/samplesheet.csv"
        params.ref         = "data/reference/ref.fa"
        params.known_sites = ""
        params.snpeff_db   = "GRCh38.99"

        process {
            cpus   = 2
            memory = "4.GB"
            time   = "1.h"
        }
    }
}

// ─── NEXTFLOW REPORTING ────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
    fields    = "task_id,name,status,exit,realtime,cpus,memory,disk,rss,peak_rss,vmem,peak_vmem,rchar,wchar"
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/dag.svg"
    overwrite = true
}

// ─── CACHE ────────────────────────────────────────────────────────────────
// Nextflow work directory (intermediate files)
workDir = "./work"

// Enable caching of containers (avoid re-pulling)
docker.cacheStrategy   = "symlink"
singularity.cacheDir   = "$HOME/.singularity/cache"
